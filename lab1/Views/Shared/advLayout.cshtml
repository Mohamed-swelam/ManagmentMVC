<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>@ViewData["Title"] - University System</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- FontAwesome -->
    @* <link rel="stylesheet" href="~/css/font-awesome.min.css"> *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- Custom -->
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>

<body class="app-shell">

    <!--  Header -->
    <header id="header" class="bg-white shadow-sm sticky-top app-header">
        <div class="container">

            <nav class="navbar navbar-expand-lg navbar-light">

                <!-- Logo -->
                <a class="navbar-brand fw-bold fs-4 d-flex align-items-center gap-2" asp-controller="Student" asp-action="Index">
                    <img src="~/images/img/logo.png" style="height:40px;" alt="logo">
                    <span class="app-brand-text">University System</span>
                </a>

                    <!-- Toggle -->
                    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <!-- Menu -->
                    <div class="collapse navbar-collapse" id="nav">

                        <!-- Links -->
                        <ul class="navbar-nav ms-auto align-items-center">

                            <li class="nav-item me-2">
                                <button type="button" class="btn theme-toggle-btn" id="themeToggle" aria-label="Toggle theme">
                                    <i class="fa-solid fa-moon" id="themeToggleIcon"></i>
                                </button>
                            </li>

                            @if (User.Identity.IsAuthenticated)
                            {
                                if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link fw-semibold app-nav-link" asp-controller="Student" asp-action="Index">
                                            <i class="fa-solid fa-user-graduate me-1"></i> Students
                                        </a>
                                    </li>

                                    <li class="nav-item">
                                        <a class="nav-link fw-semibold app-nav-link" asp-controller="Department" asp-action="Index">
                                            <i class="fa-solid fa-building me-1"></i> Departments
                                        </a>
                                    </li>

                                    <li class="nav-item">
                                        <a class="nav-link fw-semibold app-nav-link" asp-controller="Course" asp-action="Index">
                                            <i class="fa-solid fa-book me-1"></i> Courses
                                        </a>
                                    </li>

                                    <li class="nav-item">
                                        <a class="nav-link fw-semibold app-nav-link" asp-controller="Instructor" asp-action="Index">
                                            <i class="fa-solid fa-chalkboard-user me-1"></i> Instructors
                                        </a>
                                    </li>
                                }

                                else if (User.IsInRole("User"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link fw-semibold app-nav-link" asp-controller="Student" asp-action="Index">
                                            <i class="fa-solid fa-user-graduate me-1"></i> Students
                                        </a>
                                    </li>

                                    <li class="nav-item">
                                        <a class="nav-link fw-semibold app-nav-link" asp-controller="Course" asp-action="Index">
                                            <i class="fa-solid fa-book me-1"></i> Courses
                                        </a>
                                    </li>
                                }

                                <!-- Username -->
                                <li class="nav-item ms-3">
                                    <span class="nav-link text-primary fw-bold app-user-chip">
                                        <i class="fa-solid fa-user me-1"></i> Hello @User.FindFirst("FirstName")?.Value
                                    </span>
                                </li>

                                <!-- Logout -->
                                <li class="nav-item">
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="btn app-btn-outline-danger btn-sm ms-2">
                                            <i class="fa-solid fa-right-from-bracket me-1"></i> Logout
                                        </button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link fw-semibold app-nav-link" asp-controller="Account" asp-action="Login">
                                        <i class="fa-solid fa-right-to-bracket me-1"></i> Login
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="btn app-btn-primary ms-2 px-3 rounded-3" asp-controller="Account" asp-action="Register">
                                        <i class="fa-solid fa-user-plus me-1"></i> Register
                                    </a>
                                </li>
                            }

                    </ul>

                </div>

            </nav>

        </div>
    </header>
    @{
        var currentPath = Context.Request.Path;
        var hideHero =
            currentPath.StartsWithSegments("/Account/Login", StringComparison.OrdinalIgnoreCase) ||
            currentPath.StartsWithSegments("/Account/Register", StringComparison.OrdinalIgnoreCase);
    }

    @if (!hideHero)
    {
        <!-- 🔥 Hero Area -->
         <div class="hero-area app-hero-area">
            <div class="hero-bg d-flex align-items-center justify-content-center text-center">

                <!-- Overlay -->
                <div class="hero-overlay"></div>

                <div class="container position-relative">

                    <ul class="list-inline mb-0 text-white fw-bold text-shadow
                        px-3 py-2 rounded d-inline-block hero-text"
                        >

                        <li class="list-inline-item fs-6 fs-md-5">
                            <a asp-controller="Student" asp-action="Index" class="text-white text-decoration-none">
                                Home
                            </a>
                        </li>

                        <li class="list-inline-item">/</li>

                        <li class="list-inline-item fs-6 fs-md-5">
                            @RenderSection("Page", required: false)
                        </li>

                    </ul>

                </div>
            </div>
        </div>
    }
    <div class="container my-4 content-shell">
        <div class="row justify-content-center">
            <div class="col-12 col-xl-11">
                <div class="content-card">
                @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <footer class="bg-dark text-white mt-5 pt-4 app-footer">

        <div class="container">
            <div class="row text-center text-md-start">

                <!-- About -->
                <div class="col-md-4 mb-3">
                    <h5 class="fw-bold text-info">EduSite</h5>
                    <p class="small text-light">
                        Simple university system for managing students, courses, and instructors.
                    </p>
                </div>

                <!-- Links -->
                <div class="col-md-4 mb-3">
                    <h6 class="fw-semibold text-info">Quick Links</h6>
                    <ul class="list-unstyled">
                        <li><a class="text-light text-decoration-none" asp-controller="Student" asp-action="Index">Students</a></li>
                        <li><a class="text-light text-decoration-none" asp-controller="Department" asp-action="Index">Departments</a></li>
                        <li><a class="text-light text-decoration-none" asp-controller="Course" asp-action="Index">Courses</a></li>
                        <li><a class="text-light text-decoration-none" asp-controller="Instructor" asp-action="Index">Instructors</a></li>
                    </ul>
                </div>

                <!-- Contact -->
                <div class="col-md-4 mb-3">
                    <h6 class="fw-semibold text-info">Contact</h6>
                    <p class="mb-1 text-light">
                        <i class="fa-solid fa-envelope me-2 text-info"></i> info@university.com
                    </p>
                    <p class="mb-1 text-light">
                        <i class="fa-solid fa-phone me-2 text-success"></i> +20 100 123 4567
                    </p>
                    <p class="text-light">
                        <i class="fa-solid fa-location-dot me-2 text-danger"></i> Alexandria, Egypt
                    </p>
                </div>

            </div>

            <hr class="border-secondary">

            <!-- Bottom -->
            <div class="text-center pb-3">
                <p class="mb-0 small text-light">
                    © 2026 University System | All Rights Reserved
                </p>
            </div>
        </div>

    </footer>
    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            const body = document.body;
            const toggle = document.getElementById('themeToggle');
            const icon = document.getElementById('themeToggleIcon');
            const savedTheme = localStorage.getItem('app-theme');

            if (savedTheme === 'dark') {
                body.classList.add('theme-dark');
                if (icon) icon.className = 'fa-solid fa-sun';
            }

            if (toggle) {
                toggle.addEventListener('click', function () {
                    body.classList.toggle('theme-dark');
                    const isDark = body.classList.contains('theme-dark');
                    localStorage.setItem('app-theme', isDark ? 'dark' : 'light');
                    if (icon) icon.className = isDark ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
                });
            }
        })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>