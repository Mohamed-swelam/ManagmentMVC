@model GetStudentWithFullDetialsVM

<div class="container mt-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <div class="bg-primary text-white p-4 d-flex align-items-center gap-4">

            @if (!string.IsNullOrEmpty(Model.Image))
            {
                <img src="@Model.Image"
                     class="rounded-circle border border-3 border-white"
                     style="width:120px; height:120px; object-fit:cover;">
            }
            else
            {
                <div class="bg-light rounded-circle d-flex justify-content-center align-items-center"
                     style="width:120px; height:120px;">
                    <i class="fa-solid fa-user text-secondary" style="font-size:60px;"></i>
                </div>
            }

            <div>
                <h3 class="mb-1">@Model.Name</h3>
                <span class="badge bg-light text-dark">@Model.DeptName</span>
            </div>
        </div>

        <div class="card-body p-4">
            <div class="row mb-4">
                <div class="col-md-6">
                    <p><i class="fa fa-envelope me-2 text-primary"></i>@Model.Email</p>
                    <p><i class="fa fa-phone me-2 text-success"></i>@Model.Phone</p>
                </div>
                <div class="col-md-6">
                    <p><i class="fa fa-location-dot me-2 text-danger"></i>@Model.Address</p>
                </div>
            </div>

            <hr />

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">Courses</h4>
                <a asp-action="AssignCourse"
                   asp-controller="StudCourse"
                   asp-route-id="@Model.SSN"
                   class="btn btn-info btn-sm rounded-pill px-3">
                    + Add Course
                </a>
            </div>

            @if (Model.Courses.Any())
            {
                <div class="list-group">

                    @foreach (var course in Model.Courses)
                    {
                        var isFail = course.Grade < course.MinimumDegree;

                        <div class="list-group-item d-flex justify-content-between align-items-center rounded-3 mb-2 shadow-sm">

                            <div>
                                <h6 class="mb-1">@course.CourseName</h6>

                                <span class="badge @(isFail ? "bg-danger" : "bg-success")">
                                    Grade: @course.Grade
                                </span>
                            </div>

                            <div class="d-flex gap-2">
                                <a asp-action="EditGrade"
                                   asp-controller="StudCourse"
                                   asp-route-studentId="@Model.SSN"
                                   asp-route-courseId="@course.CourseId"
                                   class="btn btn-outline-warning btn-sm rounded-pill">
                                    Edit
                                </a>

                                <a asp-action="UnAssignCourse"
                                   asp-controller="StudCourse"
                                   asp-route-studentId="@Model.SSN"
                                   asp-route-courseId="@course.CourseId"
                                   class="btn btn-outline-danger btn-sm rounded-pill">
                                    Delete
                                </a>
                            </div>

                        </div>
                    }

                </div>
            }
            else
            {
                <div class="alert alert-warning text-center">
                    No courses assigned yet.
                </div>
            }

        </div>
    </div>
</div>

@section Page {
        Student Details / @Model.Name
}