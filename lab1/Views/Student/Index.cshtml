@model IEnumerable<lab1.Models.Student>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (User.IsInRole("Admin"))
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Students</h3>
        <a class="btn app-btn-primary" href="/Student/Add">Add Student</a>
    </div>
}
else
{
    <h3 class="mb-3">Students</h3>
}

<div class="table-responsive">
<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th scope="col">SSN</th>
            <th scope="col">Name</th>
            <th scope="col">Email</th>
            <th scope="col">Address</th>
            <th scope="col">Phone</th>
            <th scope="col">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model){
            <tr>
                <th scope="row">@item.SSN</th>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.Address</td>
                <td>@item.Phone</td>
                <td>
                    <a asp-action="Details" asp-controller="Student" asp-route-id="@item.SSN"
                       class="btn btn-info btn-sm">
                        View
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-controller="Student" asp-route-id="@item.SSN"
                        class="btn btn-warning">
                            Edit
                        </a>                
                    }
                </td>
            </tr>
        }

    </tbody>
</table>
</div>

@section Page{
    Students
}