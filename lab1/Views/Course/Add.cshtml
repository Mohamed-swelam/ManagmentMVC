@model Course



<form asp-action="Add" asp-controller="Course" method="post">
    <div class="form-group">
        <label asp-for="crs_Name"></label>
        <input class="form-control" asp-for="crs_Name">
        <span asp-validation-for="crs_Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Description"></label>
        <input class="form-control" asp-for="Description">
        <span asp-validation-for="Description" class="text-danger"></span>

    </div>
    <div class="form-group">
        <label asp-for="Topics"></label>
        <input class="form-control" asp-for="Topics">
        <span asp-validation-for="Topics" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="TotalDegree"></label>
        <input class="form-control" asp-for="TotalDegree">
        <span asp-validation-for="TotalDegree" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="MinimumDegree"></label>
        <input class="form-control" asp-for="MinimumDegree">
        <span asp-validation-for="MinimumDegree" class="text-danger"></span>
    </div>
    <br />
    <button type="submit" class="btn btn-primary">Submit</button>
</form>


@section Page {
                Add Course
}

@section Scripts{
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}