@model IEnumerable<Course>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (User.IsInRole("Admin"))
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Courses</h3>
        <a class="btn app-btn-primary" asp-action="Add" asp-controller="Course">Add Course</a>
    </div>
}
else
{
    <h3 class="mb-3">Courses</h3>
}

<div class="table-responsive">
<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th scope="col">Course ID</th>
            <th scope="col">Course Name</th>
            <th scope="col">Description</th>
            <th scope="col">TotalDegree</th>
            <th scope="col">MinimumDegree</th>
            <th scope="col">Topics</th>
            <th scope="col">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <th scope="row">@item.crs_Id</th>
                <td>@item.crs_Name</td>
                <td>@item.Description</td>
                <td>@item.TotalDegree</td>
                <td>@item.MinimumDegree</td>
                <td>@item.Topics</td>
                @* <td>
                    <a asp-action="getbyId" asp-controller="Student" asp-route-id="@item.SSN"
                       class="btn btn-info btn-sm">
                        View
                    </a>

                    <a asp-action="Edit" asp-controller="Student" asp-route-id="@item.SSN"
                       class="btn btn-warning">
                        Edit
                    </a>
                </td> *@
            </tr>
        }

    </tbody>
</table>
</div>

@section Page {
    Courses
}