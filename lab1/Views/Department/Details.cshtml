@model Department


<div class="page-section">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Department Details</h3>
        <a class="btn btn-outline-primary" asp-action="Index" asp-controller="Department">Back To List</a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <h2 class="card-title text-primary">@Model.DeptName</h2>
            <p class="card-text"><strong>Location:</strong> @Model.Location</p>
            <p class="card-text"><strong>Phone:</strong> @Model.PhoneNumber</p>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card shadow border-0 text-center h-100">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Students</h6>
                    <h2 class="text-primary fw-bold">@Model.Students.Count</h2>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow border-0 text-center h-100">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Instructors</h6>
                    <h2 class="text-success fw-bold">@Model.Instructors.Count</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header app-gradient-header text-white">
            Students
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Students)
                    {
                        <tr>
                            <td>@s.Name</td>
                            <td>@s.Email</td>
                            <td>@s.Phone</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-header app-gradient-header text-white">
            Instructors
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Degree</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var i in Model.Instructors)
                    {
                        <tr>
                            <td>@i.ins_Name</td>
                            <td>@i.ins_Email</td>
                            <td>@i.ins_Degree</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Page{
            Department Details (@Model.DeptName)
}