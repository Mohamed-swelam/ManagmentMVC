@model Department

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Edit Department</h3>
    <a asp-action="Index" asp-controller="Department" class="btn btn-outline-primary">Back to List</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form asp-action="Edit" asp-controller="Department" asp-route-id="@Model.DeptId" method="post">
            <input type="hidden" asp-for="DeptId" />
            <partial name="DepartmentFormPV" />

            <button type="submit" class="btn app-btn-primary mt-2">Save Changes</button>
        </form>
    </div>
</div>

@section Page {
                Edit Department (@Model.DeptName)
}


