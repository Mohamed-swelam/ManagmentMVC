@model List<Instructor>


@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Instructors</h3>
    <a class="btn app-btn-primary" asp-action="Add" asp-controller="Instructor">Add Instructor</a>
</div>

<div class="table-responsive">
<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th scope="col">ID</th>
            <th scope="col">Name</th>
            <th scope="col">Email</th>
            <th scope="col">Age</th>
            <th scope="col">Salary</th>
            <th scope="col">Department Name</th>
            <th scope="col">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <th scope="row">@item.ins_Id</th>
                <td>@item.ins_Name</td>
                <td>@item.ins_Email</td>
                <td>@item.Age</td>
                <td>@item.Salary</td>
                @if(item.Department == null)
                {
                    <td>Not Assigned</td>
                }
                else
                {
                    <td>@item.Department.DeptName</td>
                }
                <td>
                    <a asp-action="Details" asp-controller="Instructor" asp-route-id="@item.ins_Id"
                       class="btn btn-info btn-sm">
                        View
                    </a>

                    <a asp-action="Edit" asp-controller="Instructor" asp-route-id="@item.ins_Id"
                       class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete" asp-controller="Instructor" asp-route-id="@item.ins_Id"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
        }

    </tbody>
</table>
</div>

@section Page {
        Instructors
}


