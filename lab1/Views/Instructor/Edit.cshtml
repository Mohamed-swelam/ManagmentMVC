@model Instructor

@{
    var depts = new SelectList(ViewBag.Departments, "DeptId", "DeptName");
}

<div class="row">
    <div class="col-12"><a asp-action="Index" asp-controller="Instructor" class="btn btn-outline-primary">Back to List</a></div>
    <div class="col-md-8">
        <form asp-action="Edit" asp-controller="Instructor" asp-route-id="@Model.ins_Id" method="post" >
            <input type="hidden" asp-for="ins_Id" />
            
            <div class="form-group">
                <label asp-for="ins_Name"></label>
                <input class="form-control" asp-for="ins_Name">
                <span asp-validation-for="ins_Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ins_Address"></label>
                <input class="form-control" asp-for="ins_Address">
                <span asp-validation-for="ins_Address" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Salary"></label>
                <input class="form-control" asp-for="Salary">
                <span asp-validation-for="Salary" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ins_Email"></label>
                <input class="form-control" asp-for="ins_Email">
                <span asp-validation-for="ins_Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Age"></label>
                <input class="form-control" asp-for="Age">
                <span asp-validation-for="Age" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ins_Degree"></label>
                <input class="form-control" asp-for="ins_Degree">
                <span asp-validation-for="ins_Degree" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DeptId"></label>
                <select class="form-control" asp-for="DeptId" asp-items="depts">
                </select>
            </div>

            <br />
            <button type="submit" class="btn btn-primary">Submit</button>
        </form>
    </div>

</div>

@section Page {
            Edit Instructor / @Model.ins_Id
}

@section Scripts{
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}