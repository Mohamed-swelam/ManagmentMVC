@model Instructor



<form asp-action="Add" asp-controller="Instructor" method="post" >
    <div class="form-group">
        <label asp-for="ins_Name"></label>
        <input class="form-control" asp-for="ins_Name">
        <span asp-validation-for="ins_Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="ins_Address"></label>
        <input class="form-control" asp-for="ins_Address">
        <span asp-validation-for="ins_Address" class="text-danger"></span>

    </div>
    <div class="form-group">
        <label asp-for="Salary"></label>
        <input class="form-control" asp-for="Salary">
        <span asp-validation-for="Salary" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Age"></label>
        <input class="form-control" asp-for="Age">
        <span asp-validation-for="Age" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ins_Email"></label>
        <input class="form-control" asp-for="ins_Email">
        <span asp-validation-for="ins_Email" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ins_Degree"></label>
        <input class="form-control" asp-for="ins_Degree">
        <span asp-validation-for="ins_Degree" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>DeptId</label>
        <select class="form-control" name="DeptId">
            @foreach (var d in ViewBag.Departments)
            {
                <option value="@d.DeptId">@d.DeptName</option>
            }
        </select>
    </div>
    <br />
    <button type="submit" class="btn btn-primary">Submit</button>
</form>

@section Page {
            Add Instructor
}
@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}